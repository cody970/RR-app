generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id            String         @id @default(cuid())
  name          String
  users         User[]
  writers       Writer[]
  publishers    Publisher[]
  works         Work[]
  recordings    Recording[]
  statements    Statement[]
  findings      Finding[]
  tasks         Task[]
  retroactiveClaims RetroactiveClaim[]
  splitSignoffs SplitSignoff[]
  royaltyPeriods RoyaltyPeriod[]
  auditLogs     AuditLog[]
  activities    Activity[]
  auditJobs     AuditJob[]
  apiKeys       ApiKey[]
  ingestJobs    IngestJob[]
  notifications Notification[]
  dspReports    DspReport[]
  cwrRegistrations CwrRegistration[]
  catalogScans  CatalogScan[]
  registrationBatches RegistrationBatch[]
  syncQuotes    SyncQuote[]
  syncLicenses  SyncLicense[]
  syncPlacements SyncPlacement[]
  mlcMatchJobs  MLCMatchJob[]
  opportunities    LicenseOpportunity[]
  licenseRequests  LicenseRequest[]
  licenses         License[]
  payeeLedgers     PayeeLedger[]
  payouts          Payout[]
  // DMP Integration back-relations
  workAcknowledgements WorkAcknowledgement[]
  cwrExports       CwrExport[]
  ackImports       AckImport[]
  // Content ID monitoring
  contentIdMonitors ContentIdMonitor[]
  contentIdJobs    ContentIdJob[]
  // Webhook system
  webhooks         Webhook[]
  currency      String         @default("USD")
  
  // Stripe Billing Fields
  stripeCustomerId       String?   @unique
  stripeSubscriptionId   String?   @unique
  stripePriceId          String?
  stripeCurrentPeriodEnd DateTime?
  subscriptionStatus     String    @default("freemium")

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  invitations   OrgInvitation[]
}

// Organization invitation for adding users to existing orgs
// Addresses CODE_REVIEW issue #7: OAuth users should join existing orgs via invitation
model OrgInvitation {
  id            String       @id @default(cuid())
  email         String       // Email to invite
  role          String       @default("VIEWER") // Default role is VIEWER, not OWNER
  token         String       @unique // Secure invitation token (hashed)
  status        String       @default("PENDING") // PENDING, ACCEPTED, EXPIRED, REVOKED
  expiresAt     DateTime     // Invitation expiration
  invitedById   String?      // User who sent the invitation (optional for initial setup)
  organization  Organization @relation(fields: [orgId], references: [id])
  orgId         String
  createdAt     DateTime     @default(now())
  acceptedAt    DateTime?    // When the invitation was accepted

  @@unique([email, orgId]) // One active invitation per email per org
  @@index([token])
  @@index([orgId, status])
  @@index([email, status])
}

model IngestJob {
  id           String   @id @default(cuid())
  type         String
  status       String   @default("COMPLETED")
  filename     String?
  totalRows    Int      @default(0)
  importedRows Int      @default(0)
  failedRows   Int      @default(0)
  errors       String?
  orgId        String
  userId       String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  organization Organization @relation(fields: [orgId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  @@index([orgId, createdAt])
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  passwordHash  String
  role          String         @default("OWNER")
  organization  Organization   @relation(fields: [orgId], references: [id])
  orgId         String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  auditLogs     AuditLog[]
  activities    Activity[]
  ingestJobs    IngestJob[]
  notifications Notification[]
  writerId      String?
  writer        Writer?        @relation(fields: [writerId], references: [id])
  publisherId   String?
  publisher     Publisher?     @relation(fields: [publisherId], references: [id])
}

model Writer {
  id            String         @id @default(cuid())
  name          String
  // DMP-enhanced: split name into first/last for CWR formatting
  firstName     String?
  lastName      String?
  ipiCae        String?        // IPI Name Number (11 digits)
  ipiBase       String?        // IPI Base Number (I-NNNNNNNNN-C)
  isni          String?        // ISNI (16 digits, ISO 27729)
  // Society affiliations
  prSociety     String?        // Performing Rights society TIS-N code
  mrSociety     String?        // Mechanical Rights society TIS-N code
  srSociety     String?        // Synchronisation Rights society TIS-N code
  // General agreement (DMP: generally_controlled)
  generallyControlled Boolean  @default(false)
  saan          String?        // Society-Assigned Agreement Number
  publisherFee  Float?         // Publisher admin fee percentage (0-100)
  notes         String?
  accountNumber String?        // Internal account reference
  organization  Organization   @relation(fields: [orgId], references: [id])
  orgId         String
  works         WorkWriter[]
  users         User[]
  payeeLedgers  PayeeLedger[]
  payouts       Payout[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@unique([ipiCae, orgId])
  @@index([orgId])
  @@index([lastName, orgId])
}

model Publisher {
  id            String         @id @default(cuid())
  name          String
  // DMP-enhanced: split name for CWR formatting
  firstName     String?
  lastName      String?
  ipiCae        String?        // IPI Name Number (11 digits)
  ipiBase       String?        // IPI Base Number (I-NNNNNNNNN-C)
  isni          String?        // ISNI (16 digits, ISO 27729)
  // Society affiliations (stored as TIS-N codes)
  prSociety     String?        // Performing Rights society TIS-N code
  mrSociety     String?        // Mechanical Rights society TIS-N code
  srSociety     String?        // Synchronisation Rights society TIS-N code
  // Share percentages for CWR SPT records
  prSharePercent  Float?       // PR share (0-100)
  mrSharePercent  Float?       // MR share (0-100)
  srSharePercent  Float?       // SR share (0-100)
  organization  Organization   @relation(fields: [orgId], references: [id])
  orgId         String
  users         User[]
  payeeLedgers  PayeeLedger[]
  payouts       Payout[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@unique([ipiCae, orgId])
  @@index([orgId])
}

model Work {
  id            String         @id @default(cuid())
  title         String
  iswc          String?
  // DMP-enhanced fields
  workId        String?        // Internal/publisher work ID
  versionType   String?        // ORI=Original, MOD=Modified, LIB=Library, etc.
  originalTitle String?        // Original title if this is a modified version
  lastChange    DateTime?      // Tracks metadata changes to drive REV transactions
  durationSec   Int?           // Work duration in seconds (for CWR)
  recordedIndicator Boolean    @default(false) // Has this work been commercially recorded?
  libraryCode   String?        // Music library code
  cdIdentifier  String?        // CD/album identifier
  language      String?        // ISO 639-2 primary language code
  organization  Organization   @relation(fields: [orgId], references: [id])
  orgId         String
  writers       WorkWriter[]
  recordings    Recording[]
  registrations Registration[]
  syncQuotes    SyncQuote[]
  syncLicenses  SyncLicense[]
  syncPlacements SyncPlacement[]
  opportunities LicenseOpportunity[]
  licenseRequests LicenseRequest[]
  licenses      License[]
  splitSignoffs SplitSignoff[]
  alternateTitles AlternateTitle[]
  acknowledgements WorkAcknowledgement[]
  cwrExports    CwrExportWork[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@unique([iswc, orgId])
  @@index([orgId])
  @@index([iswc])
  @@index([title, orgId])
  @@index([lastChange])
}

model WorkWriter {
  work          Work           @relation(fields: [workId], references: [id])
  workId        String
  writer        Writer         @relation(fields: [writerId], references: [id])
  writerId      String
  splitPercent  Float
  role          String?        // Legacy role field
  // DMP-enhanced WriterInWork fields
  capacity      String?        // CWR writer capacity: CA, A, C, E, ES, PA, TR, etc.
  controlled    Boolean        @default(false) // Is this writer controlled by the publisher?
  saan          String?        // Society-Assigned Agreement Number (overrides writer-level)
  publisherFee  Float?         // Publisher admin fee % for this work (overrides writer-level)
  relativeShare Float?         // Relative share within controlled writers (0-100)

  @@id([workId, writerId])
  @@index([writerId])
}

model Recording {
  id            String         @id @default(cuid())
  title         String
  isrc          String?
  durationSec   Int?
  // DMP-enhanced Recording fields
  recordingTitle  String?      // Recording-specific title (if different from work title)
  versionTitle    String?      // Version description e.g. "Radio Edit", "Acoustic"
  releaseDate     DateTime?    // Commercial release date
  recordLabel     String?      // Record label name
  artistName      String?      // Primary artist name
  artistIsni      String?      // Artist ISNI (ISO 27729)
  ean             String?      // EAN-13 barcode of the release
  audioFileUrl    String?      // URL to audio file (for preview/matching)
  work          Work?          @relation(fields: [workId], references: [id])
  workId        String?
  organization  Organization   @relation(fields: [orgId], references: [id])
  orgId         String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  // Content ID monitoring
  contentIdMonitors ContentIdMonitor[]

  @@unique([isrc, orgId])
  @@index([orgId])
  @@index([isrc])
  @@index([title, orgId])
  @@index([artistName, orgId])
}

model Registration {
  id                   String    @id @default(cuid())
  work                 Work      @relation(fields: [workId], references: [id])
  workId               String
  society              String
  status               String
  totalSplitRegistered Float
  submissionId         String?
  confirmationId       String?
  submittedAt          DateTime?
  acknowledgedAt       DateTime?
  submittedVia         String?   // TUNEREGISTRY, CWR_UPLOAD, MANUAL
  errors               String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([workId])
  @@index([society])
}

model RegistrationBatch {
  id             String   @id @default(cuid())
  orgId          String
  status         String   @default("PENDING") // PENDING, PROCESSING, COMPLETE, FAILED
  totalWorks     Int      @default(0)
  submitted      Int      @default(0)
  accepted       Int      @default(0)
  rejected       Int      @default(0)
  societies      String[] // ["ASCAP", "BMI", "MLC", ...]
  submittedVia   String   // TUNEREGISTRY, CWR_GENERATE
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization @relation(fields: [orgId], references: [id])

  @@index([orgId])
}

model Statement {
  id            String         @id @default(cuid())
  source        String         // ASCAP, BMI, MLC, SOUNDEXCHANGE
  period        String         // YYYY-Q# or YYYY-MM
  fileName      String?
  fileType      String?        // ASCAP_CSV, BMI_CSV, MLC_CSV, SOUNDEXCHANGE_CSV
  totalAmount   Decimal        @default(0) @db.Decimal(18, 4)
  lineCount     Int            @default(0)
  status        String         @default("PROCESSED") // PROCESSING, PROCESSED, FAILED
  organization  Organization   @relation(fields: [orgId], references: [id])
  orgId         String
  lines         StatementLine[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([orgId, period])
  @@index([source])
}

model StatementLine {
  id              String         @id @default(cuid())
  statement       Statement      @relation(fields: [statementId], references: [id])
  statementId     String
  isrc            String?
  iswc            String?
  uses            Int
  amount         Decimal        @db.Decimal(18, 4)
  amountOriginal Decimal?       @db.Decimal(18, 4)
  currency        String         @default("USD")
  title           String?
  artist          String?
  society         String?        // ASCAP, BMI, MLC, SOUNDEXCHANGE
  territory       String?
  useType         String?        // PERFORMANCE, MECHANICAL, DIGITAL, SYNC
  rate            Decimal?       @db.Decimal(18, 6)
  workId          String?
  // Smart matching metadata for AI-powered fuzzy matching
  matchMethod     String?        // EXACT_ISWC, EXACT_ISRC, EXACT_TITLE, NORMALIZED_TITLE, FUZZY_HIGH, FUZZY_MEDIUM, FUZZY_LOW, CONTAINS, USER_CORRECTED, USER_REJECTED, NONE
  matchConfidence Int?           // 0-100 confidence score
  needsReview     Boolean        @default(false) // True for fuzzy matches that need user confirmation
  reviewedAt      DateTime?      // When the match was reviewed by user
  reviewedBy      String?        // User ID who reviewed the match
  createdAt       DateTime       @default(now())

  @@index([statementId])
  @@index([isrc])
  @@index([iswc])
  @@index([title])
  @@index([workId])
  @@index([needsReview])
}

model RoyaltyPeriod {
  id              String       @id @default(cuid())
  orgId           String
  workId          String?
  society         String       // ASCAP, BMI, MLC, SOUNDEXCHANGE
  period          String       // YYYY-Q# e.g. 2025-Q1
  totalAmount     Decimal      @default(0) @db.Decimal(18, 4)
  totalUses       Int          @default(0)
  avgRate         Decimal?     @db.Decimal(18, 6) // avg per-use rate
  useType         String?      // PERFORMANCE, MECHANICAL, DIGITAL
  previousAmount  Decimal?     @db.Decimal(18, 4) // prior period amount for trend
  changePercent   Float?       // period-over-period % change
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  organization    Organization @relation(fields: [orgId], references: [id])

  @@unique([orgId, workId, society, period])
  @@index([orgId, period])
  @@index([orgId, society])
  @@index([workId])
}

model Finding {
  id              String       @id @default(cuid())
  type            String
  severity        String
  status          String       @default("OPEN")
  confidence      Int
  estimatedImpact Decimal?     @db.Decimal(18, 4)
  recoveredAmount Decimal?     @db.Decimal(18, 4)
  amountOriginal  Decimal?     @db.Decimal(18, 4)
  currency        String       @default("USD")
  resourceType    String?
  resourceId      String
  metadataFix     String?
  organization    Organization @relation(fields: [orgId], references: [id])
  orgId           String
  tasks           Task[]
  registrationGap RegistrationGap? @relation(fields: [gapId], references: [id])
  gapId           String?
  createdAt       DateTime     @default(now())

  @@index([orgId, estimatedImpact])
  @@index([orgId, status])
  @@index([orgId, severity])
  @@index([orgId, createdAt])
  @@index([orgId, type])
}

model Task {
  id            String         @id @default(cuid())
  finding       Finding        @relation(fields: [findingId], references: [id])
  findingId     String
  assigneeEmail String?
  status        String         @default("OPEN")
  notes         String?
  organization  Organization   @relation(fields: [orgId], references: [id])
  orgId         String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model AuditLog {
  id            String         @id @default(cuid())
  action        String
  details       String
  evidenceHash  String
  user          User?          @relation(fields: [userId], references: [id])
  userId        String?
  organization  Organization   @relation(fields: [orgId], references: [id])
  orgId         String
  timestamp     DateTime       @default(now())
}

model RateLimit {
  key           String         @id
  count         Int            @default(0)
  expiresAt     DateTime
}

model Activity {
  id           String   @id @default(cuid())
  orgId        String
  userId       String
  action       String
  resourceId   String?
  resourceType String?
  details      String?
  createdAt    DateTime @default(now())

  organization Organization @relation(fields: [orgId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  @@index([orgId, createdAt])
}

model AuditJob {
  id           String   @id @default(cuid())
  orgId        String
  status       String   @default("PENDING")
  findingsCount Int      @default(0)
  error        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  organization Organization @relation(fields: [orgId], references: [id])

  @@index([orgId])
}

model ApiKey {
  id           String   @id @default(cuid())
  key          String   @unique
  name         String?
  orgId        String
  createdAt    DateTime @default(now())
  lastUsedAt   DateTime?
  revokedAt    DateTime?

  organization Organization @relation(fields: [orgId], references: [id])

  @@index([orgId])
}

model WebhookEvent {
  id        String   @id // Stripe event ID
  type      String
  createdAt DateTime @default(now())

  @@index([createdAt])
}

// ---------- Webhook System ----------

model Webhook {
  id               String             @id @default(cuid())
  orgId            String
  url              String             @db.VarChar(2048)
  secret           String             // HMAC signing secret (whsec_...)
  events           String[]           // Event types to subscribe to ("*" for all)
  enabled          Boolean            @default(true)
  description      String?            @db.VarChar(500)
  failureCount     Int                @default(0) // Consecutive failures, auto-disable at 10
  lastDeliveredAt  DateTime?
  lastFailedAt     DateTime?
  lastStatusCode   Int?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  organization     Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  deliveries       WebhookDelivery[]

  @@index([orgId])
  @@index([enabled, failureCount])
}

model WebhookDelivery {
  id           String    @id @default(cuid())
  webhookId    String
  event        String    // Event type (e.g., "finding.created")
  payload      String    @db.Text // JSON payload sent
  statusCode   Int?      // HTTP response status
  responseBody String?   @db.VarChar(1024) // First 1KB of response
  duration     Int?      // Request duration in ms
  success      Boolean   @default(false)
  attempts     Int       @default(1) // Number of delivery attempts
  nextRetryAt  DateTime? // For retry scheduling
  createdAt    DateTime  @default(now())

  webhook      Webhook   @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId, createdAt])
  @@index([success, createdAt])
}

model Notification {
  id           String   @id @default(cuid())
  orgId        String
  userId       String
  title        String
  message      String
  type         String   @default("INFO") // INFO, SUCCESS, WARNING, ERROR
  read         Boolean  @default(false)
  link         String?  // Optional navigation link
  createdAt    DateTime @default(now())

  organization Organization @relation(fields: [orgId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  @@index([userId, read])
  @@index([orgId, createdAt])
}

model DspReport {
  id             String   @id @default(cuid())
  source         String
  period         String
  territory      String?
  isrc           String
  title          String
  artist         String?
  streams        Int
  revenue        Decimal  @db.Decimal(18, 4)
  perStreamRate  Decimal  @db.Decimal(18, 8)
  orgId          String
  createdAt      DateTime @default(now())

  organization   Organization @relation(fields: [orgId], references: [id])

  @@index([orgId])
  @@index([isrc])
}

model CwrRegistration {
  id             String   @id @default(cuid())
  workTitle      String
  iswc           String?
  society        String?
  territory      String?
  publisherName  String?
  publisherIpi   String?
  writerName     String?
  writerIpi      String?
  shares         Float?
  recordType     String?
  rawRecord      String?
  orgId          String
  createdAt      DateTime @default(now())

  organization   Organization @relation(fields: [orgId], references: [id])

  @@index([orgId])
}

model SyncQuote {
  id           String   @id @default(cuid())
  workId       String
  orgId        String
  clientName   String
  projectName  String
  proposedFee  Decimal  @db.Decimal(18, 4)
  status       String   @default("PENDING") // PENDING, ACCEPTED, REJECTED
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  work         Work         @relation(fields: [workId], references: [id])
  organization Organization @relation(fields: [orgId], references: [id])

  @@index([orgId])
  @@index([workId])
}

model SyncLicense {
  id           String   @id @default(cuid())
  quoteId      String?  @unique
  workId       String
  orgId        String
  licenseeName String
  projectName  String
  fee          Decimal  @db.Decimal(18, 4)
  terms        String?
  status       String   @default("ACTIVE") // ACTIVE, EXPIRED, TERMINATED
  validFrom    DateTime?
  validUntil   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  work         Work         @relation(fields: [workId], references: [id])
  organization Organization @relation(fields: [orgId], references: [id])

  @@index([orgId])
  @@index([workId])
}

model SyncPlacement {
  id             String   @id @default(cuid())
  workId         String
  orgId          String
  mediaType      String   // TV, FILM, AD, GAME
  productionName String
  episodeOrScene String?
  airDate        DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  work           Work         @relation(fields: [workId], references: [id])
  organization   Organization @relation(fields: [orgId], references: [id])

  @@index([orgId])
  @@index([workId])
}

model CatalogScan {
  id                String            @id @default(cuid())
  orgId             String
  status            String            @default("PENDING") // PENDING, SCANNING, COMPLETE, FAILED
  totalWorks        Int               @default(0)
  totalRecordings   Int               @default(0)
  unregisteredCount Int               @default(0)
  scannedCount      Int               @default(0)
  error             String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  organization      Organization      @relation(fields: [orgId], references: [id])
  gaps              RegistrationGap[]

  @@index([orgId])
}

model RegistrationGap {
  id              String       @id @default(cuid())
  scanId          String
  workId          String?
  recordingId     String?
  title           String
  isrc            String?
  iswc            String?
  artistName      String?
  society         String       // ASCAP, BMI, SESAC, MLC, SoundExchange
  gapType         String       // MISSING_WORK, MISSING_RECORDING, MISSING_SPLIT, NO_REGISTRATION
  confidence      Int          // 0-100 matching confidence
  estimatedImpact Decimal?     @db.Decimal(18, 4)
  status          String       @default("OPEN") // OPEN, REGISTERING, REGISTERED, DISMISSED
  songviewMatch   Json?
  musicbrainzId   String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  scan            CatalogScan  @relation(fields: [scanId], references: [id])
  findings        Finding[]
  claims          RetroactiveClaim[]

  @@index([scanId])
  @@index([status])
  @@index([gapType])
}

model RetroactiveClaim {
  id              String           @id @default(cuid())
  gapId           String
  organizationId  String
  targetSociety   String
  yearsClaimed    Int              @default(2)
  estimatedValue  Decimal?         @default(0) @db.Decimal(18, 4)
  status          String           @default("GENERATED") // GENERATED, SUBMITTED, PAID, REJECTED
  lodContent      String?          @db.Text
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  gap             RegistrationGap  @relation(fields: [gapId], references: [id])
  organization    Organization     @relation(fields: [organizationId], references: [id])
}

model SplitSignoff {
  id              String       @id @default(cuid())
  workId          String
  organizationId  String
  targetEmail     String
  writerName      String
  proposedSplit   Float
  token           String       @unique
  status          String       @default("PENDING") // PENDING, APPROVED, DISPUTED
  disputeReason   String?
  ipAddress       String?
  signedAt        DateTime?
  expiresAt       DateTime
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  work            Work         @relation(fields: [workId], references: [id])
  organization    Organization @relation(fields: [organizationId], references: [id])
}

model MLCMatchJob {
  id              String   @id @default(cuid())
  orgId           String
  status          String   @default("PENDING") // PENDING, RUNNING, COMPLETED, FAILED
  totalWorks      Int      @default(0)
  matchesFound    Int      @default(0)
  matchesProposed Int      @default(0)
  error           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization    Organization @relation(fields: [orgId], references: [id])
  results         MLCMatchResult[]

  @@index([orgId])
}

model MLCMatchResult {
  id              String   @id @default(cuid())
  jobId           String
  workTitle       String
  workId          String?
  recordingTitle  String?
  recordingISRC   String?
  recordingArtist String?
  status          String   @default("FOUND") // FOUND, PROPOSED, ACCEPTED, REJECTED, NO_MATCH
  confidence      Int?
  mlcRecordingId  String?
  createdAt       DateTime @default(now())

  job             MLCMatchJob @relation(fields: [jobId], references: [id])

  @@index([jobId])
  @@index([status])
}

// -----------------------------------------------------------------------------
// Licensing & Sync
// -----------------------------------------------------------------------------

model LicenseOpportunity {
  id          String   @id @default(cuid())
  orgId       String
  title       String
  description String?
  budget      String?
  deadline    DateTime?
  media       String?
  territory   String?
  status      String   @default("OPEN") // OPEN, CLOSED, FULFILLED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  organization Organization @relation(fields: [orgId], references: [id])
  work         Work?        @relation(fields: [workId], references: [id])
  workId       String?

  @@index([orgId])
  @@index([status])
}

model LicenseRequest {
  id               String   @id @default(cuid())
  orgId            String
  workId           String
  requesterName    String
  requesterEmail   String
  requesterCompany String?
  projectType      String
  projectTitle     String?
  media            String?
  territory        String?
  term             String?
  budget           Decimal? @db.Decimal(18, 4)
  status           String   @default("PENDING") // PENDING, REVIEWING, APPROVED, REJECTED
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  organization Organization @relation(fields: [orgId], references: [id])
  work         Work         @relation(fields: [workId], references: [id])
  License      License?

  @@index([orgId])
  @@index([workId])
  @@index([status])
}

model License {
  id           String   @id @default(cuid())
  orgId        String
  workId       String
  requestId    String?  @unique
  licenseType  String
  licenseeName String
  fee          Decimal  @db.Decimal(18, 4)
  startDate    DateTime?
  endDate      DateTime?
  territory    String?
  media        String?
  documentUrl  String?
  status       String   @default("ACTIVE") // EXECUTED, ACTIVE, EXPIRED, TERMINATED
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  organization Organization    @relation(fields: [orgId], references: [id])
  work         Work            @relation(fields: [workId], references: [id])
  request      LicenseRequest? @relation(fields: [requestId], references: [id])

  @@index([orgId])
  @@index([workId])
  @@index([status])
}

// -----------------------------------------------------------------------------
// DMP Integration — Society Reference Table
// -----------------------------------------------------------------------------

model Society {
  id        String   @id @default(cuid())
  tisN      String   @unique  // TIS-N numeric code e.g. "010"
  name      String            // Full society name e.g. "ASCAP"
  country   String?           // ISO 3166-1 alpha-2 country code
  label     String?           // Short display label

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tisN])
  @@index([name])
}

// -----------------------------------------------------------------------------
// DMP Integration — Alternate Titles
// -----------------------------------------------------------------------------

model AlternateTitle {
  id        String   @id @default(cuid())
  workId    String
  title     String
  titleType String   @default("AT") // AT=Alternate, OT=Original, FT=Formal, IT=Incorrect, OL=Original Language, TT=Translated
  language  String?  // ISO 639-2 language code

  work      Work     @relation(fields: [workId], references: [id], onDelete: Cascade)

  @@index([workId])
}

// -----------------------------------------------------------------------------
// DMP Integration — Work Acknowledgements (ACK file processing)
// -----------------------------------------------------------------------------

model WorkAcknowledgement {
  id             String    @id @default(cuid())
  workId         String
  orgId          String
  societyCode    String    // TIS-N code e.g. "010"
  societyName    String?   // Human-readable society name
  remoteWorkId   String?   // Society's own work ID
  iswcAssigned   String?   // ISWC assigned by society
  date           DateTime?
  status         String    // RA=Registration Accepted, AS=Accepted with changes, RA=Rejected, NP=Not Processed
  statusMessage  String?
  transactionType String?  // NWR, REV, WRK
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  work           Work         @relation(fields: [workId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [orgId], references: [id])

  @@index([workId])
  @@index([orgId])
  @@index([societyCode])
  @@index([status])
}

// -----------------------------------------------------------------------------
// DMP Integration — CWR Export tracking
// -----------------------------------------------------------------------------

model CwrExport {
  id             String          @id @default(cuid())
  orgId          String
  filename       String
  version        String          // "2.1", "2.2", "3.0", "3.1"
  senderCode     String?
  sequenceNumber Int             @default(1)
  workCount      Int             @default(0)
  status         String          @default("GENERATED") // GENERATED, SUBMITTED, ACKNOWLEDGED
  fileContent    String?         @db.Text
  submittedAt    DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  organization   Organization    @relation(fields: [orgId], references: [id])
  works          CwrExportWork[]

  @@index([orgId])
  @@index([status])
}

model CwrExportWork {
  cwrExportId  String
  workId       String
  transactionType String @default("NWR") // NWR or REV

  cwrExport    CwrExport @relation(fields: [cwrExportId], references: [id], onDelete: Cascade)
  work         Work      @relation(fields: [workId], references: [id])

  @@id([cwrExportId, workId])
  @@index([workId])
}

// -----------------------------------------------------------------------------
// DMP Integration — ACK Import tracking
// -----------------------------------------------------------------------------

model AckImport {
  id              String    @id @default(cuid())
  orgId           String
  filename        String
  senderCode      String?
  senderName      String?
  receiverCode    String?
  creationDate    DateTime?
  version         String?   // "2.1", "2.2", "3.0"
  totalAcks       Int       @default(0)
  acceptedCount   Int       @default(0)
  rejectedCount   Int       @default(0)
  conflictCount   Int       @default(0)
  status          String    @default("PROCESSED") // PROCESSING, PROCESSED, FAILED
  errors          String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  organization    Organization @relation(fields: [orgId], references: [id])

  @@index([orgId])
  @@index([status])
}

// -----------------------------------------------------------------------------
// Financial Accounting & Payouts
// -----------------------------------------------------------------------------

model PayeeLedger {
  id              String   @id @default(cuid())
  orgId           String
  writerId        String?
  publisherId     String?
  statementLineId String?  // Source: statement ingest
  licenseId       String?  // Source: sync license
  amount          Decimal  @db.Decimal(18, 4) // Payee portion (revenue * splitPercent)
  currency        String   @default("USD")
  type            String   // EARNING, ADVANCE_RECOUPMENT, FEE
  status          String   @default("UNPAID") // UNPAID, PAID, CARRIED_FORWARD
  payoutId        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization    Organization @relation(fields: [orgId], references: [id])
  writer          Writer?      @relation(fields: [writerId], references: [id])
  publisher       Publisher?   @relation(fields: [publisherId], references: [id])
  payout          Payout?      @relation(fields: [payoutId], references: [id])

  @@index([orgId])
  @@index([writerId])
  @@index([publisherId])
  @@index([payoutId])
  @@index([status])
}

model Payout {
  id              String   @id @default(cuid())
  orgId           String
  writerId        String?
  publisherId     String?
  period          String   // e.g., "2026-Q1"
  totalAmount     Decimal  @db.Decimal(18, 4)
  status          String   @default("PROCESSING") // PROCESSING, ISSUED, FAILED
  statementUrl    String?  // PDF accounting statement link
  paidAt          DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization    Organization    @relation(fields: [orgId], references: [id])
  writer          Writer?         @relation(fields: [writerId], references: [id])
  publisher       Publisher?      @relation(fields: [publisherId], references: [id])
  ledgerEntries   PayeeLedger[]

  @@index([orgId])
  @@index([writerId])
  @@index([publisherId])
}

// ---------- Exchange Rates for Multi-Currency Support ----------

model ExchangeRate {
  id           String   @id @default(cuid())
  date         DateTime @db.Date  // Date for which this rate applies
  baseCurrency String   @default("USD") // Base currency (typically USD)
  currency     String   // Target currency code (EUR, GBP, etc.)
  rate         Float    // Exchange rate: 1 baseCurrency = rate currency
  source       String?  // Source of rate (e.g., "ECB", "OPENEXCHANGERATES")
  createdAt    DateTime @default(now())

  @@unique([date, baseCurrency, currency])
  @@index([date])
  @@index([currency])
}

// ─────────────────────────────────────────────
// Content ID / Audio Fingerprint Monitoring
// ─────────────────────────────────────────────

model ContentIdMonitor {
  id                String              @id @default(cuid())
  recordingId       String
  orgId             String
  platform          String              // YouTube, Facebook, Instagram, TikTok
  assetId           String?             // External Content ID asset identifier
  registrationStatus String             @default("PENDING") // PENDING, REGISTERED, FAILED
  policy            String              @default("MONETIZE") // MONETIZE, BLOCK, TRACK
  fingerprint       String?             // Audio fingerprint hash for matching
  lastCheckedAt     DateTime?           // Last time usage was checked
  totalViews        Int                 @default(0)
  totalClaims       Int                 @default(0)
  estimatedRevenue  Float               @default(0)
  error             String?             // Error message if registration failed
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  recording         Recording           @relation(fields: [recordingId], references: [id])
  organization      Organization        @relation(fields: [orgId], references: [id])
  usages            ContentIdUsage[]

  @@unique([recordingId, platform])
  @@index([orgId])
  @@index([recordingId])
  @@index([registrationStatus])
  @@index([platform])
}

model ContentIdUsage {
  id                String            @id @default(cuid())
  monitorId         String
  platform          String            // Platform where usage was detected
  videoId           String?           // External video/content ID
  videoTitle        String?           // Title of the video/content
  channelName       String?           // Channel/creator name
  viewCount         Int               @default(0)
  claimStatus       String            @default("ACTIVE") // ACTIVE, RELEASED, DISPUTED
  estimatedRevenue  Float             @default(0)
  usageDurationSec  Int?              // Duration of music used (in seconds)
  detectedAt        DateTime          @default(now())
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  monitor           ContentIdMonitor  @relation(fields: [monitorId], references: [id])

  @@index([monitorId])
  @@index([platform])
  @@index([claimStatus])
}

model ContentIdJob {
  id          String   @id @default(cuid())
  orgId       String
  status      String   @default("PENDING") // PENDING, RUNNING, COMPLETE, FAILED
  totalRecordings Int  @default(0)
  processedCount  Int  @default(0)
  newUsagesFound  Int  @default(0)
  estimatedRevenue Float @default(0)
  error       String?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  organization Organization @relation(fields: [orgId], references: [id])

  @@index([orgId])
  @@index([status])
}
