# .env.example

# Database Configuration
DATABASE_URL=your_database_url_here
DATABASE_USER=your_database_user_here
DATABASE_PASSWORD=your_database_password_here

# Redis Configuration
REDIS_URL=your_redis_url_here

# NextAuth Configuration
NEXTAUTH_URL=your_nextauth_url_here
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_ADAPTER=your_adapter_here

# OAuth Configuration
OAUTH_CLIENT_ID=your_oauth_client_id_here
OAUTH_CLIENT_SECRET=your_oauth_client_secret_here

# Stripe Configuration
STRIPE_API_KEY=your_stripe_api_key_here

# Music API Configuration
MUSIC_API_URL=your_music_api_url_here
MUSIC_API_KEY=your_music_api_key_here

# Currency Exchange Rates (Optional - defaults to simulated rates)
OPENEXCHANGERATES_API_KEY=your_openexchangerates_api_key_here

# RoyaltyRadar Configuration
ROYALTYRADAR_IPI=000000000

# Add your specific configuration values for deployment
# MLC (Mechanical Licensing Collective) Configuration
# Bulk Data API - requires MLC Bulk Data Access enrollment
MLC_API_KEY=your_mlc_api_key_here
MLC_API_URL=https://portal.themlc.com/api/v1

# DURP (Distributor Unmatched Recordings Portal) - requires distributor enrollment
MLC_DURP_KEY=your_mlc_durp_key_here
MLC_DURP_URL=https://portal.themlc.com/api/v1/durp

# MLC Portal Credentials (for legacy automation - optional)
MLC_PORTAL_EMAIL=your_mlc_portal_email_here
MLC_PORTAL_PASSWORD=your_mlc_portal_password_here
